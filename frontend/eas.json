{
    "cli": {
        "version": ">= 14.7.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": true
            }
        },
        "development-device": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal"
        },
        "testflight": {
            "distribution": "store",
            "autoIncrement": true,
            "env": {
                "APP_ENV": "production"
            },
            "ios": {
                "resourceClass": "m-medium"
            }
        },
        "production": {
            "distribution": "store",
            "autoIncrement": true,
            "env": {
                "APP_ENV": "production"
            },
            "ios": {
                "resourceClass": "m-medium"
            },
            "android": {
                "buildType": "app-bundle"
            }
        }
    },
    "submit": {
        "production": {}
    }
}